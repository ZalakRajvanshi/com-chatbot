# ── Database ──────────────────────────────────────────
# Local dev (default):
DATABASE_URL=sqlite:///./app.db
# Production (Supabase Postgres) — replace with your connection string:
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRE_HOURS=24

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── CORS — comma-separated allowed origins ────────────
# Local dev (default):
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production — add your Vercel domain:
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Password reset link base ──────────────────────────
# In production, point this at your deployed frontend URL:
RESET_LINK_BASE=http://localhost:5173/reset-password
# RESET_LINK_BASE=https://your-app.vercel.app/reset-password

# ── SMTP (optional) — for sending password reset emails ──
# If unset, reset links print to backend logs (dev mode).
# Brevo is recommended for free tier (300 emails/day):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=your-brevo-login
#   SMTP_PASSWORD=your-brevo-smtp-key
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@theproductfolks.com
SMTP_FROM_NAME=The Product Folks

# ── Public signup ─────────────────────────────────────
# Comma-separated email domains allowed to sign up. Empty = anyone.
SIGNUP_ALLOWED_DOMAINS=

# ── Optional: Abhay Jani's system prompt addon ────────
SYSTEM_PROMPT_ADDON=
